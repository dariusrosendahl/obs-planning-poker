{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Planning Poker",
  "version": "0.1.0",
  "identifier": "com.planningpoker.desktop",
  "build": {
    "frontendDist": "../src/panel",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Planning Poker",
        "width": 420,
        "height": 580,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../public/card/*": "public/card/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
