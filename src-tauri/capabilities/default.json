{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri-plugin-capabilities/refs/heads/v2/schemas/capabilities.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-top",
    "core:window:allow-is-always-on-top"
  ]
}
